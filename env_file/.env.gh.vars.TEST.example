# GitHub Actions Environment: TEST の Variables 用（dotenv 形式）
# このファイルを .env.gh.vars.TEST にコピーし、値を埋める。
# 1行1つ KEY=VALUE。TEST 用のリソース名・DB名等に差し替えること。

AZURE_RESOURCE_GROUP=your-test-resource-group
AZURE_FUNCTIONAPP_NAME=your-test-function-app-name
AZURE_LOCATION=japanwest
AZURE_RESOURCE_GROUP_NAME=your-test-resource-group-name
AZURE_STORAGE__ACCOUNT_NAME=your-test-storage-account-name
TIMER_TRIGGER_SCHEDULE=0 0 * * * *
CONTAINER__MONGO_USE_DB=test_crawler_db
CONTAINER__MONGO_USER=your-test-mongo-user
CONTAINER_MONGO__RESOURCE_CPU=1
CONTAINER_MONGO__RESOURCE_MEMORY_IN_GB=1.0
CONTAINER_MONGO__DNS_NAME_LABEL=test-news-clip-mongo
CONTAINER_MONGO__MONGO_CONF=mongod_tls.conf
CONTAINER_MONGO__MONGO_INITDB_ROOT_USERNAME=your-test-root-username
CONTAINER_MONGO__MONGO_TAG=7.0.4-jammy
CONTAINER_MONGO__PORT=27017
CONTAINER_NEWS_CRAWLER__RESOURCE_CPU=1
CONTAINER_NEWS_CRAWLER__RESOURCE_MEMORY_IN_GB=3.2
CONTAINER_NEWS_CRAWLER__TAG=test-0.18.0
CONTAINER_CRAWLER__MONGO_PORT=27017
CONTAINER_CRAWLER__MONGO_TLS=true
CONTAINER_CRAWLER__MONGO_TLS_CA_FILE=/home/common_user/mongo-key/ca.crt
CONTAINER_CRAWLER__MONGO_TLS_CERTTIFICATE_KEY_FILE=/home/common_user/mongo-key/mongo_client.pem
CONTAINER_CRAWLER__NOTICE__SLACK_CHANNEL_ID__ERROR=your-test-channel-id
CONTAINER_CRAWLER__NOTICE__SLACK_CHANNEL_ID__NOMAL=your-test-channel-id
CONTAINER_CRAWLER__PREFECT__API_URL=http://127.0.0.1:4200/api
CONTAINER_CRAWLER__SLEEP_TIME_AFTER_PREFECT_SERVER_STARTUP=30
