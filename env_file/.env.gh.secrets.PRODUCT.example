# GitHub Actions Environment: PRODUCT の Secrets 用（dotenv 形式）
# このファイルを .env.gh.secrets.PRODUCT にコピーし、値を埋める。機密のため .env.gh.secrets.* は .gitignore 済み。
# CLIENT_ID はデプロイ用（GitHub Actions の az ログイン）と関数実行用（Function App 内の DefaultAzureCredential）で別クライアントにする想定。

AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_CLIENT_ID__GITHUB_DEPLOY=your-deploy-sp-client-id
AZURE_CLIENT_ID__FUNCTION_EXEC=your-function-exec-sp-client-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_SECRET__FUNCTION_EXEC=your-function-exec-sp-client-secret
AZURE_STORAGE__ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE__CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net
ACI_DOCKER_IMAGE__REGISTRY_USERNAME=your-registry-username
ACI_DOCKER_IMAGE__REGISTRY_PASSWORD=your-registry-password
CONTAINER__MONGO_PASS=your-mongo-pass
CONTAINER_CRAWLER__NOTICE__SLACK_TOKEN=xoxb-xxx
CONTAINER_MONGO__MONGO_INITDB_ROOT_PASSWORD=your-mongo-root-password
